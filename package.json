{
  "name": "grit-hub",
  "version": "1.0.0",
  "description": "Custom Copilot agent repo with shared skills and instructions.",
  "main": "scripts/setup.js",
  "bin": {
    "copilot-setup": "scripts/setup.js"
  },
  "scripts": {
    "agent:remove": "node scripts/remove-agent.js",
    "copilot:memory:clear": "node scripts/cleanup-copilot-memory.js",
    "agent:sync": "node scripts/cleanup.js && node scripts/setup.js --all --skip-python --skip-cleanup",
    "postinstall": "node scripts/setup.js --all",
    "setup": "node scripts/setup.js",
    "setup:dry": "node scripts/setup.js --dry-run",
    "setup:all": "node scripts/setup.js --all",
    "test": "node scripts/setup.js --dry-run"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "pptxgenjs": "^3.12.0"
  },
  "keywords": [
    "copilot",
    "ai-agent",
    "skills",
    "github-copilot",
    "custom-agents",
    "developer-tools"
  ],
  "author": "CDCP Copilot Team",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  }
}
